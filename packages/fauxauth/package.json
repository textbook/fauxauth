{
  "name": "fauxauth",
  "version": "11.0.0",
  "description": "Helper application for testing OAuth clients",
  "bin": {
    "fauxauth": "./lib/server.js"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "type": "module",
  "files": [
    "/lib",
    "/views"
  ],
  "engines": {
    "node": "^22.12 || >=24"
  },
  "scripts": {
    "prebuild": "rimraf lib/*",
    "build": "tsc --project tsconfig.build.json",
    "postbuild": "chmod u+x ./lib/server.js && cpy ../../LICENSE ../../README.md .",
    "start": "node $npm_package_bin_fauxauth",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:cover": "npm run test -- --coverage",
    "test:watch": "npm run test -- --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/textbook/fauxauth.git"
  },
  "keywords": [
    "express",
    "mock",
    "oauth",
    "stub",
    "test",
    "testing"
  ],
  "author": "Jonathan Sharpe <mail@jonrshar.pe>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/textbook/fauxauth/issues"
  },
  "homepage": "https://github.com/textbook/fauxauth#readme",
  "funding": "https://ko-fi.com/textbook",
  "dependencies": {
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "jiff": "^0.7.3",
    "lodash.clonedeep": "^4.5.0",
    "morgan": "^1.10.1",
    "pug": "^3.0.4",
    "xml2js": "^0.6.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash.clonedeep": "^4.5.9",
    "@types/morgan": "^1.9.10",
    "@types/supertest": "^7.2.0",
    "@types/xml2js": "^0.4.14",
    "@types/yargs": "^17.0.35",
    "cpy-cli": "^7.0.0",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2"
  }
}
